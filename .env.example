# Environment
ENVIRONMENT=development

# Django
SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8020,http://127.0.0.1:8020

# Application
APP_PORT=8020
TIME_ZONE=America/Guayaquil

# Django database connection
DB_NAME=sistema_iglesia
DB_USER=sistema_iglesia_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_PUBLIC_PORT=5434

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Multi-church defaults
IGLESIA_NACIONAL_CODIGO=NACIONAL
IGLESIA_NACIONAL_NOMBRE=Iglesia Nacional

# Sessions
SESSION_COOKIE_AGE=3600
SESSION_COOKIE_NAME=sistema_iglesia_sessionid
CSRF_COOKIE_NAME=sistema_iglesia_csrftoken

# HTTPS/security headers
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_X_FORWARDED_HOST=False
SECURE_PROXY_SSL_HEADER_ENABLED=False

# Development helpers
ENABLE_DJANGO_EXTENSIONS=False

# Login brute-force protection
AXES_FAILURE_LIMIT=3
AXES_COOLOFF_TIME=0.25
